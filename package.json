{
  "name": "pi-taskplane-planner",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "planner",
    "taskplane",
    "specs"
  ],
  "bin": {
    "planner": "bin/planner.mjs"
  },
  "pi": {
    "prompts": [
      "./.pi/prompts/plan-*.md"
    ]
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "test": "bun test",
    "test:runtime-e2e": "PLANNER_RUNTIME_E2E=1 bun test tests/runtime-e2e.test.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
